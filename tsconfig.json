{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "jsx": "react-jsx",
    "types": ["vitest/globals", "@testing-library/jest-dom", "node"],
    "paths": {
      "@better-teams/app/*": ["./packages/app/src/*"],
      "@better-teams/core": ["./packages/core/src/index.ts"],
      "@better-teams/core/*": ["./packages/core/src/*"],
      "@better-teams/desktop-electron/preload": [
        "./packages/desktop-electron/src/preload/contracts.ts"
      ],
      "@better-teams/ui": ["./packages/ui/src/index.ts"],
      "@better-teams/ui/*": ["./packages/ui/src/*"]
    }
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "packages/**/*.d.ts",
    "e2e/**/*.ts",
    "forge.config.ts",
    "vitest.config.ts",
    "vitest.setup.ts",
    "playwright.config.ts"
  ]
}
