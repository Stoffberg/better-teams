{
  "name": "better-teams",
  "productName": "Better Teams",
  "version": "1.0.0",
  "description": "A calmer, faster Microsoft Teams desktop experience with a focused custom UI",
  "private": true,
  "type": "module",
  "keywords": [
    "better-teams",
    "tauri",
    "microsoft-teams",
    "productivity",
    "desktop"
  ],
  "scripts": {
    "branding:generate": "node scripts/generate-branding.mjs",
    "dev": "tauri dev",
    "start": "tauri dev",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "package": "tauri build",
    "build": "tauri build",
    "verify": "bun run typecheck && bun run check && bun run test:coverage && bun run build",
    "audit": "bun audit",
    "lefthook:install": "lefthook install",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "vite:dev": "vite",
    "vite:build": "vite build"
  },
  "author": "Dirk Beukes",
  "license": "MIT",
  "engines": {
    "bun": ">=1.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.1",
    "happy-dom": "^20.8.4",
    "lefthook": "^2.1.4",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.0",
    "vite": "^8.0",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@fontsource-variable/figtree": "^5.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/query-async-storage-persister": "^5.95.2",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-query-persist-client": "^5.95.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-sql": "^2.3.2",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "linkedom": "^0.18.12",
    "lucide-react": "^0.562.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  }
}
